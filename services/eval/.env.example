# Cloudflare R2 / S3 Configuration
ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com/your-bucket-name
ACCESS_KEY_ID=your-r2-access-key-id
SECRET_ACCESS_KEY=your-r2-secret-access-key
BUCKET_NAME=your-bucket-name

# PostgreSQL Schema Configuration
SCHEMA_NAME=benchmark

# Dataset Configuration
DATASET_NAME=your-dataset-name

# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# Gemini API for ground truth extraction
GEMINI_API_KEY=your-gemini-api-key-here
