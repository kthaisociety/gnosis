# Gnosis Environment Configuration
# Copy this file to .env and fill in the values.

# -- Gateway Service --
# Host and port for the main FastAPI gateway server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# -- VLM gRPC Server --
# Host and port for the VLM gRPC server
VLM_SERVER_HOST=0.0.0.0
VLM_SERVER_PORT=50051

# Target for the gateway to connect to the VLM server
VLM_SERVER_GRPC_TARGET=localhost:50051

# -- Database --
# Connection details for the PostgreSQL database, as a full URL
DATABASE_URL_DEV="postgresql://postgres:password@localhost:5432/gnosis"

# -- External Services --
# Google API Key for GenAI models
GOOGLE_API_KEY="your-google-api-key"

# Modal credentials for cloud compute
# It is recommended to use Modal's environment variables for this
# MODAL_TOKEN_ID="your-modal-token-id"
# MODAL_TOKEN_SECRET="your-modal-token-secret"
# Copy this file to .env and fill in values as needed.

# -- Core --
LOGGING_LEVEL=INFO

# -- Database --
# Connection details for PostgreSQL, as a full URL.
DATABASE_URL=

# -- Gateway (REST API) --
TITLE="The Gnosis API"
HOST=127.0.0.1
PORT=8000
WORKERS=1

# -- gRPC / VLM Server --
GRPC_BIND=0.0.0.0
GRPC_PORT=50051

# Gateway gRPC client target
SERVER_IP=localhost

# -- Image Handling --
MAX_IMAGE_SIZE_BYTES=20971520

# -- Redis Queue (Gateway) --
QUEUE_ENABLED=false
REDIS_URL=redis://localhost:6379 # redis://redis:6379/0 for docker
QUEUE_KEY=jobs
MAX_QUEUE_SIZE=100
RESULT_PREFIX=result_
JOB_TIMEOUT_S=480
RESULT_TTL_SECONDS=120
RESULT_POLL_INTERVAL_S=0.02

# -- Rate Limiting (Gateway) --
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_IP_PER_MIN=10
RATE_LIMIT_GLOBAL_PER_MIN=60
RATE_LIMIT_WINDOW_SECONDS=60

# -- Modal (cloud compute) --
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# -- Gemini (tests) --
GEMINI_API_KEY=

# -- Eval Service --
GATEWAY_URL=http://127.0.0.1:8000

# Cloudflare R2 / S3 Configuration
ENDPOINT_URL=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
BUCKET_NAME=benchmark-data

# PostgreSQL
DATABASE_URL=
SCHEMA_NAME=benchmark


# -- Frontend --
VITE_NEON_AUTH_URL=




GATEWAY_URL="http://127.0.0.1:8000"
