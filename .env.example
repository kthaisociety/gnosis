# --- Gateway API Settings ---
API_TITLE="The Gnosis API"
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_IP=10
RATE_LIMIT_GLOBAL=60

# --- Redis & Queue Configuration ---
# Use 'redis://redis:6379' when running with Docker Compose
REDIS_URL=redis://localhost:6379 
QUEUE_KEY=jobs
MAX_QUEUE_SIZE=100
RESULT_PREFIX=result_
JOB_TIMEOUT_S=480
RESULT_TTL_SECONDS=120

# --- Modal Inference Runner ---
# Required for the 'modal' runner in process_router.py
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# --- gRPC Inference Runner ---
# Used by gateway to communicate with vlm_server
SERVER_IP=localhost
GRPC_PORT=50051

# --- Database Settings ---
# Used by lib/src/lib/db/client.py
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gnosis_db
DB_USER=postgres
DB_PASSWORD=your_password_here