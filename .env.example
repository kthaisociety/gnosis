# Gnosis Environment Configuration
# Copy this file to .env and fill in the values.

# -- Gateway Service --
# Host and port for the main FastAPI gateway server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# -- VLM gRPC Server --
# Host and port for the VLM gRPC server
VLM_SERVER_HOST=0.0.0.0
VLM_SERVER_PORT=50051

# Target for the gateway to connect to the VLM server
VLM_SERVER_GRPC_TARGET=localhost:50051

# -- Database --
# Connection details for the PostgreSQL database, as a full URL
DATABASE_URL_DEV="postgresql://postgres:password@localhost:5432/gnosis"

# -- External Services --
# Google API Key for GenAI models
GOOGLE_API_KEY="your-google-api-key"

# Modal credentials for cloud compute
# It is recommended to use Modal's environment variables for this
# MODAL_TOKEN_ID="your-modal-token-id"
# MODAL_TOKEN_SECRET="your-modal-token-secret"