# Copy this to a file named ".env" and fill in secrets before running.

# REST Application
TITLE=The Gnosis API
HOST=127.0.0.1
PORT=8000
WORKERS=1

# gRPC client/server
SERVER_IP=localhost
GRPC_PORT=50051

# Logging
LOGGING_LEVEL=INFO

# Request / upload limits
ALLOWED_MIME_TYPES=image/jpeg,image/png
MAX_IMAGE_SIZE_BYTES=20971520

# Inference / model settings
USE_GPU=0
GEMINI_API_KEY=

# Modal deployment tokens (optional, used by some compute scripts/tests)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Metrics
METRICS_SAMPLE_RATE=1

# TEMPORARY test helpers
API_URL=http://127.0.0.1:8000/process
