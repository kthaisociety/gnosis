# ── Core ──
PROD=false
LOGGING_LEVEL=INFO

# ── Gateway ──
TITLE="The Gnosis API"
HOST=127.0.0.1
PORT=8000
WORKERS=1
# Comma-separated origins allowed by CORS. For VM+Vercel: add your Vercel URL.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── gRPC / VLM Server ──
SERVER_IP=127.0.0.1
GRPC_PORT=50051
GRPC_BIND=0.0.0.0

# ── Modal (remote GPU) ──
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
GPU_TYPE=L4
GPU_COUNT=4

# ── Redis Queue ──
QUEUE_ENABLED=false
REDIS_URL="redis://localhost:6379"
QUEUE_KEY=jobs
MAX_QUEUE_SIZE=100
RESULT_PREFIX=result_
JOB_TIMEOUT_S=480
RESULT_TTL_SECONDS=120
RESULT_POLL_INTERVAL_S=0.02

# ── Rate Limiting ──
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_IP_PER_MIN=10
RATE_LIMIT_GLOBAL_PER_MIN=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Image Handling ──
MAX_IMAGE_SIZE_BYTES=20971520

# ── Database ──
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"
SCHEMA_NAME="benchmark"

# ── S3 / Cloudflare R2 ──
BUCKET_NAME="benchmark-data"
ENDPOINT_URL=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=

# -- Eval Service --
GATEWAY_URL="http://127.0.0.1:8000"

# ── Frontend (Vite) ──
# Both vars are baked into the JS bundle at build time (pass as Docker build args).
VITE_API_URL=http://127.0.0.1:8000
VITE_NEON_AUTH_URL=
